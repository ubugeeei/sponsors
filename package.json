{
  "name": "ubugeeei-sponsors",
  "private": true,
  "version": "0.0.1",
  "description": "ubugeeei's sponsors",
  "author": "ubugeeei",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "vite build",
    "generate": "node dist/generator.js",
    "preview": "pnpm build && OUTPUT_DIR=preview node dist/generator.js && vite preview --outDir preview",
    "lint": "oxlint --type-aware src",
    "fmt": "oxfmt --write src config.ts"
  },
  "dependencies": {
    "@octokit/graphql": "^8.2.0",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "oxlint-tsgolint": "^0.14.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
